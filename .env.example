# Needlstack environment variables
# Copy this file to .env and fill in values

# Database path (relative to project root)
DB_PATH=db/needlstack.db

# Data directory for cached files
DATA_DIR=data

# Logs directory
LOG_DIR=logs

# Cloudflare R2 (for export_data.py uploads)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=needlstack

# Set LOCAL_EXPORT=1 to write to docs/data/ instead of uploading to R2 (dev only)
# LOCAL_EXPORT=1
